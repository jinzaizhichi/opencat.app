---
import { detectLocale } from '@/utils/locale'

// 旧文档路径兼容（301 永久重定向）：
//   /docs/zh-CN/*  → /zh-Hans/doc/*  （保留中文语言意图）
//   /docs/ 及其余  → /{negotiated}/doc/*
export const prerender = false

const path = Astro.params.path ?? ''

function withTrailingSlash(p: string): string {
  return p.endsWith('/') ? p : `${p}/`
}

if (path === 'zh-CN' || path.startsWith('zh-CN/')) {
  const rest = path.slice('zh-CN'.length).replace(/^\//, '')
  return Astro.redirect(withTrailingSlash(`/zh-Hans/doc/${rest}`), 301)
}

const rest = path.replace(/^\//, '')
return Astro.redirect(withTrailingSlash(`/${detectLocale(Astro.request)}/doc/${rest}`), 301)
---
